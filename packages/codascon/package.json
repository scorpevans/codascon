{
  "name": "codascon",
  "version": "2026.3.2-beta.0",
  "description": "A structural protocol for code organization with exhaustive compile-time type checking",
  "license": "MIT",
  "author": "@scorpevans",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scorpevans/codascon.git",
    "directory": "packages/codascon"
  },
  "keywords": [
    "code-as-config",
    "code-protocol",
    "double-dispatch",
    "visitor-pattern",
    "command-pattern",
    "template-pattern",
    "strategy-pattern",
    "design-patterns",
    "solid-principles",
    "type-safe",
    "compile-time",
    "typescript",
    "framework"
  ],
  "homepage": "https://github.com/scorpevans/codascon#readme",
  "bugs": {
    "url": "https://github.com/scorpevans/codascon/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.map",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --build && pnpm run build:js",
    "build:js": "tsup && cp dist/index.d.ts dist/index.d.cts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
