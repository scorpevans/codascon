{
  "name": "odetovibe",
  "version": "1.1.1",
  "description": "CLI and library for generating TypeScript code from declarative YAML codascon domain schemas",
  "license": "MIT",
  "author": "@scorpevans",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scorpevans/codascon.git",
    "directory": "packages/odetovibe"
  },
  "keywords": [
    "codascon",
    "codegen",
    "code-generation",
    "yaml",
    "cli",
    "typescript",
    "scaffold",
    "double-dispatch",
    "design-patterns"
  ],
  "homepage": "https://github.com/scorpevans/codascon",
  "bugs": {
    "url": "https://github.com/scorpevans/codascon/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "odetovibe": "./dist/cli.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc --build && chmod +x dist/cli.js",
    "test": "pnpm build && pnpm typecheck && vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.test.json",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "codascon": "workspace:*",
    "js-yaml": "^4.0.0",
    "prettier": "^3.0.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^4.1.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
